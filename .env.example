# Plantilla de configuración. Copia este archivo a `.env` y rellena lo que uses:
#   cp .env.example .env   (o en PowerShell: Copy-Item .env.example .env)

# --- Anthropic (Claude) — para: python -m engine.run --llm anthropic ---
# https://console.anthropic.com (API Keys)
ANTHROPIC_API_KEY=

# --- Modelo a usar (opcional; equivale al flag --modelo) ---
# Si se define, sobreescribe el modelo por defecto del proveedor.
TLM_MODELO=

# --- Proveedor compatible con OpenAI — para: python -m engine.run --llm openai ---
# Sirve para OpenAI y para OpenRouter, Together, DeepSeek, Ollama, etc.
OPENAI_API_KEY=
# base_url solo si NO usas OpenAI directo. Ejemplos:
#   OpenRouter -> https://openrouter.ai/api/v1
#   DeepSeek   -> https://api.deepseek.com
#   Ollama     -> http://localhost:11434/v1   (y OPENAI_API_KEY=ollama)
OPENAI_BASE_URL=
